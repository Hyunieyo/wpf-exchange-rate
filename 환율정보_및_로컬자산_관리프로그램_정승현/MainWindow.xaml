<Window x:Class="환율정보_및_로컬자산_관리프로그램_정승현.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:환율정보_및_로컬자산_관리프로그램_정승현"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <Grid>
        <StackPanel Margin="10">
            <Button x:Name="btnLoad" Content="환율 정보 조회" Height="40" Margin="0,0,0,10" Click="btnLoad_Click"/>
            <Button x:Name="btnView" Content="환율 정보 보기" Height="40" Margin="0,0,0,10" Click="btnView_Click"/>
            <DataGrid x:Name="datagrid" Height="272" Margin="0,0,0,10"/>
            <TextBlock Text="KRW 입력" FontSize="16" Margin="0,10,0,5"/>
            <TextBox x:Name="textBox1" Height="35" Margin="0,0,0,10"/>
            <Button x:Name="btnCount" Content="환율 계산" Height="40" Margin="0,0,0,10" Click="btnCount_Click"/>
            <TextBlock x:Name="textBox2" FontSize="22" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
